# Authprint — 1Password secret template (references only, no plaintext secrets)
#
# Copy to op.env.tpl (gitignored) and replace vault/item/field paths with yours:
#   cp secrets/op.env.tpl.example secrets/op.env.tpl
#
# Format: ENV_VAR=op://Vault/Item/field
# Docs: https://developer.1password.com/docs/cli/secret-references/
#
# Uncomment and edit when cloud/auth integration needs these:

# Session / Auth.js (Phase III)
# AUTH_SECRET=op://Private/Authprint Dev/auth-secret

# Google OAuth
# GOOGLE_CLIENT_ID=op://Private/Authprint Dev/google-client-id
# GOOGLE_CLIENT_SECRET=op://Private/Authprint Dev/google-client-secret

# Resend (email OTP)
# RESEND_API_KEY=op://Private/Authprint Dev/resend-api-key

# Firebase / GCP (when E28 lands)
# FIREBASE_PROJECT_ID=op://Private/Authprint Dev/firebase-project-id
# GOOGLE_APPLICATION_CREDENTIALS_JSON=op://Private/Authprint Dev/gcp-service-account

# Sentry
# SENTRY_DSN=op://Private/Authprint Dev/sentry-dsn

# PostHog (when analytics enabled)
# POSTHOG_API_KEY=op://Private/Authprint Dev/posthog-api-key
