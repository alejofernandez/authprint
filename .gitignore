# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies (workspace-aware paths — no leading slash so they match at any depth)
node_modules
.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
coverage

# next.js
.next/
out/

# production
build
dist
apps/web/build-info.json

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files — never commit plaintext secrets
.env*

# 1Password local template (personal vault/item paths; example is committed)
secrets/op.env.tpl

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# claude code — local-only settings (skills symlinked to authprint-cloud; launch.json is committed)
.claude/settings.local.json
.claude/skills/
CLAUDE.local.md

# multi-agent worktrees — Implementers work in .worktrees/<branch>/ (see AGENTS.md)
.worktrees/

# pinned local tool binaries (e.g. the gitleaks bootstrap cache) — see scripts/
.tools/

*storybook.log
storybook-static

# visual regression: commit baselines, ignore transient failure diffs/actuals
**/__snapshots__/**/__diff_output__/
