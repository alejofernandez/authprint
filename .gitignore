# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies (workspace-aware paths — no leading slash so they match at any depth)
node_modules
.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
coverage

# next.js
.next/
out/

# production
build
dist

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# claude code — local-only settings (skills + launch.json are committed)
.claude/settings.local.json

*storybook.log
storybook-static

# visual regression: commit baselines, ignore transient failure diffs/actuals
**/__snapshots__/**/__diff_output__/
